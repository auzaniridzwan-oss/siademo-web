# Client (Vite) — Web SDK
VITE_BRAZE_SDK_KEY=
VITE_BRAZE_SDK_URL=

# Serverless only (Vercel dashboard / `vercel env`) — never VITE_*
BRAZE_REST_API_KEY=
BRAZE_REST_API_URL=

# SerpAPI (Google Flights proxy) — set in Vercel Project Settings → Environment Variables
SERPAPI_API_KEY=

# Optional: if set, GET /api/serpapi/fares and /api/serpapi/pricing-trend require ?token=
CONNECTED_CONTENT_TOKEN=
